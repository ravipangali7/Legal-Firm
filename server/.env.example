# Copy to .env in this folder (server/.env). Real values are not committed.
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized JavaScript origins must include your app origin (e.g. http://localhost:5173).
GOOGLE_OAUTH_CLIENT_ID=

# SPA origin (no trailing path). eSewa success_url / failure_url are built from this; must match where users open the app.
# Example production: PUBLIC_APP_BASE_URL=https://your-domain.com
PUBLIC_APP_BASE_URL=
# Canonical origin for sitemap, share HTML, robots.txt (defaults to PUBLIC_APP_BASE_URL).
PUBLIC_SITE_URL=

# When true, applies pending core migrations on WSGI worker boot (email templates, OTP).
# Use once after deploy if GET /api/admin/email-templates/ returns 503, then turn off.
# RUN_CORE_MIGRATE_ON_STARTUP=true
